
<mvc:View
    controllerName="machineworkerapp.controller.machineWorkerApp"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m">
    
    <Page id="page" title="Maschinenführer Dashboard">
        <content>
            <List
                id="notificationList"
                items="{/NotificationSet}">
                
                <headerToolbar>
                    <Toolbar>
                        <Title text="Aktuelle Maßnahmen" level="H2"/>
                        <ToolbarSpacer /> <Button 
                            icon="sap-icon://add" 
                            text="Neue Maßnahme" 
                            type="Emphasized" 
                            press=".onOpenAddDialog" />
                    </Toolbar>
                </headerToolbar>
                <items>
                    <ObjectListItem
                        title="{Description}"
                        number="{NotifNo}">
                        <attributes>
                            <ObjectAttribute title="Equipment" text="{Equipment}" />
                            <ObjectAttribute title="Priorität" text="{Priority}" />
                        </attributes>
                        <firstStatus>
                            <ObjectStatus title="Status" text="{Status}" />
                        </firstStatus>
                    </ObjectListItem>
                </items>
            </List>
        </content>
    </Page>
    
</mvc:View>